{
  "coverageDirectory": "../coverage",
  "extensionsToTreatAsEsm": [".ts", ".tsx"],
  "moduleFileExtensions": ["js", "jsx", "ts", "tsx", "json"],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "preset": "ts-jest/presets/default-esm",
  "rootDir": "src",
  "testEnvironment": "jsdom",
  "testMatch": ["**/*.spec.tsx"],
  "transform": {
    "^.+\\.[tj]sx?$": [
      "ts-jest",
      {
        "useESM": true
      }
    ]
  },
  "verbose": true
}
